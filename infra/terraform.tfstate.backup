            "values": [
              "singleuser:\n  image:\n    name: quay.io/jupyterhub/singleuser\n    tag: \"4.1\"\n  serviceAccountName: jupyterhub-sa\n  storage:\n    capacity: 5Gi\n    extraVolumes:\n      - name: notebook\n        configMap:\n          name: submit-tpu-job-notebook\n      - name: gcloud\n        emptyDir: {}\n    extraVolumeMounts:\n      - name: notebook\n        mountPath: /tmp/notebook\n        readOnly: true\n      - name: gcloud\n        mountPath: /opt/google-cloud-sdk\n  memory:\n    limit: 4G\n    guarantee: 2G\n  cpu:\n    limit: 2\n    guarantee: 1\n  initContainers:\n    - name: install-gcloud\n      image: google/cloud-sdk:slim\n      command: [\"cp\", \"-r\", \"/usr/lib/google-cloud-sdk/.\", \"/opt/gcloud/\"]\n      volumeMounts:\n        - name: gcloud\n          mountPath: /opt/gcloud\n  lifecycleHooks:\n    postStart:\n      exec:\n        command:\n          - \"sh\"\n          - \"-c\"\n          - |\n            cp /tmp/notebook/submit_tpu_job.ipynb /home/jovyan/submit_tpu_job.ipynb 2\u003e/dev/null\n            echo 'export PATH=/opt/google-cloud-sdk/bin:$PATH' \u003e\u003e /home/jovyan/.bashrc 2\u003e/dev/null\n            true\n  cloudMetadata:\n    blockWithIptables: false\n  extraEnv:\n    PATH: \"/opt/google-cloud-sdk/bin:/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\n\nhub:\n  config:\n    Authenticator:\n      admin_users:\n        - admin\n    DummyAuthenticator:\n      password: \"vertex\"\n    JupyterHub:\n      authenticator_class: dummy\n\nproxy:\n  service:\n    type: LoadBalancer\n"
            ],
            "verify": false,
            "version": "4.3.2",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "dependencies": [
            "data.google_client_config.default",
            "google_container_cluster.primary",
            "google_project_service.apis",
            "google_service_account.jupyterhub",
            "kubernetes_namespace_v1.jupyterhub",
            "kubernetes_service_account_v1.jupyterhub"
          ]
        }
      ]
    },
    {
      "mode": "managed",
      "type": "kubernetes_config_map_v1",
      "name": "notebook",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "binary_data": {},
            "data": {
              "submit_tpu_job.ipynb": "{\n \"cells\": [\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"qmzwpdjdks8\",\n   \"metadata\": {},\n   \"source\": [\n    \"# Submit Vertex AI TPU Training from GKE\\n\",\n    \"\\n\",\n    \"This notebook demonstrates submitting a Vertex AI Custom Job with TPU accelerators from a JupyterHub instance running on GKE. Authentication uses Workload Identity — no JSON key files needed.\\n\",\n    \"\\n\",\n    \"**What this notebook does:**\\n\",\n    \"1. Verifies Workload Identity authentication\\n\",\n    \"2. Writes a Dockerfile and training script (CIFAR-10 on TPU)\\n\",\n    \"3. Builds and pushes the container image via Cloud Build\\n\",\n    \"4. Submits a Vertex AI Custom Job on TPU v5e\\n\",\n    \"5. Optionally runs the same job as a Vertex Pipeline\\n\",\n    \"\\n\",\n    \"**Google Cloud services used:** Vertex AI, Artifact Registry, Cloud Build, Cloud Storage, GKE\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"jg6pmxis31f\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 1. Install Packages\\n\",\n    \"\\n\",\n    \"Install the following packages required to execute this notebook.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"was5xzfeqjd\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"! pip3 install --upgrade --quiet google-cloud-aiplatform \\\\\\n\",\n    \"                                 google-cloud-storage \\\\\\n\",\n    \"                                 kfp \\\\\\n\",\n    \"                                 google-cloud-pipeline-components\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"bpl5x7joqop\",\n   \"metadata\": {},\n   \"source\": [\n    \"### Check tool versions\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"0o4i08z8q7k\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"! kubectl version --client\\n\",\n    \"! python3 -c \\\"import kfp; print('KFP SDK version: {}'.format(kfp.__version__))\\\"\\n\",\n    \"! python3 -c \\\"import google_cloud_pipeline_components; print('google_cloud_pipeline_components version: {}'.format(google_cloud_pipeline_components.__version__))\\\"\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"nxk5rz8a3zl\",\n   \"metadata\": {},\n   \"source\": [\n    \"## Verify GKE Environment and Workload Identity\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"y1bvhrantkf\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"import subprocess\\n\",\n    \"\\n\",\n    \"result = subprocess.run(\\n\",\n    \"    [\\\"cat\\\", \\\"/var/run/secrets/kubernetes.io/serviceaccount/namespace\\\"],\\n\",\n    \"    capture_output=True, text=True,\\n\",\n    \")\\n\",\n    \"print(f\\\"Running in Kubernetes namespace: {result.stdout}\\\")\\n\",\n    \"\\n\",\n    \"from google.auth import default\\n\",\n    \"\\n\",\n    \"credentials, project = default()\\n\",\n    \"print(f\\\"Authenticated to project: {project}\\\")\\n\",\n    \"print(\\\"Workload Identity is working - no JSON key files needed\\\")\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"tzr5xhkn5ol\",\n   \"metadata\": {},\n   \"source\": [\n    \"## Set Project Parameters\\n\",\n    \"\\n\",\n    \"Set up required parameters.\\n\",\n    \"\\n\",\n    \"- `PROJECT_ID`: Google Cloud project ID\\n\",\n    \"- `REGION`: Google Cloud region (e.g. us-central1)\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"pxmar0yj9di\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Project parameters\\n\",\n    \"PROJECT_ID = \\\"sandbox-401718\\\"          # @param {type:\\\"string\\\"}\\n\",\n    \"REGION = \\\"us-central1\\\"                  # @param {type:\\\"string\\\"}\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"71bz160ss53\",\n   \"metadata\": {},\n   \"source\": [\n    \"## TPU Training Image Preparation\\n\",\n    \"\\n\",\n    \"Set up required parameters.\\n\",\n    \"\\n\",\n    \"Container Image:\\n\",\n    \"- `VERSION`: Version or tag of the Docker image. Default set as `latest`\\n\",\n    \"- `REPO_NAME`: The name of the Artifact Registry repository that will store the container image\\n\",\n    \"- `TRAIN_IMAGE_ID`: The name of the image that will be used to run TPU training. The full image name: `\u003cREGION\u003e-docker.pkg.dev/\u003cPROJECT_ID\u003e/\u003cREPO_NAME\u003e/\u003cTRAIN_IMAGE_ID\u003e:\u003cVERSION\u003e`\\n\",\n    \"\\n\",\n    \"Custom Job and Pipeline:\\n\",\n    \"- `SERVICE_ACCOUNT`: The service account to use to run custom jobs and pipeline\\n\",\n    \"- `PIPELINE_ROOT`: Cloud Storage bucket URI for pipeline artifacts\\n\",\n    \"- `PIPELINE_REPO`: The name of the Artifact Registry repository that will store the compiled pipeline file\\n\",\n    \"- `PIPELINE_NAME`: The name of the Vertex Pipeline that is run\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"d9k75yrxjtf\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Image Parameters\\n\",\n    \"VERSION = \\\"latest\\\"\\n\",\n    \"REPO_NAME = \\\"tpu-training-repository\\\"    # @param {type:\\\"string\\\"}\\n\",\n    \"TRAIN_IMAGE_ID = \\\"tpu-train\\\"             # @param {type:\\\"string\\\"}\\n\",\n    \"\\n\",\n    \"# Vertex Custom Job parameters\\n\",\n    \"SERVICE_ACCOUNT=\\\"757654702990-compute@developer.gserviceaccount.com\\\" # @param {type:\\\"string\\\"}\\n\",\n    \"PIPELINE_ROOT = f\\\"gs://{PROJECT_ID}-tpu-pipeline-root\\\"     # @param {type:\\\"string\\\"}\\n\",\n    \"PIPELINE_REPO = \\\"tpu-training-kfp\\\"       # @param {type:\\\"string\\\"}\\n\",\n    \"PIPELINE_NAME = \\\"tpu-training-pipeline\\\"  # @param {type:\\\"string\\\"}\\n\",\n    \"\\n\",\n    \"# Working dir for model artifacts\\n\",\n    \"WORKING_DIR = f\\\"{PIPELINE_ROOT}/model\\\"\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"nusx7xk1yp\",\n   \"metadata\": {},\n   \"source\": [\n    \"### Write the Dockerfile\\n\",\n    \"\\n\",\n    \"Define the instructions to set the TPU environment and run the training script in a Dockerfile.\\n\",\n    \"\\n\",\n    \"The container uses the Vertex AI prebuilt TPU base image, installs the TensorFlow TPU wheel and `libtpu` shared library, and copies the training script.\\n\",\n    \"\\n\",\n    \"Learn more about [custom container training with TPU accelerators](https://cloud.google.com/vertex-ai/docs/training/training-with-tpu-vm#custom_container).\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"okq3qqfu3qd\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"! mkdir -p tpu-container-artifacts\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"e23gk59twcd\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"%%writefile tpu-container-artifacts/Dockerfile\\n\",\n    \"\\n\",\n    \"# Specifies base image and tag\\n\",\n    \"FROM us-docker.pkg.dev/vertex-ai/training/tf-tpu-pod-base-cp310:latest\\n\",\n    \"WORKDIR /root\\n\",\n    \"\\n\",\n    \"# Download and install `tensorflow` (2.16.1 for V5e support).\\n\",\n    \"RUN pip install https://storage.googleapis.com/cloud-tpu-tpuvm-artifacts/tensorflow/tf-2.16.1/tensorflow-2.16.1-cp310-cp310-manylinux_2_17_x86_64.manylinux2014_x86_64.whl\\n\",\n    \"\\n\",\n    \"# Download and install `libtpu` (1.10.0 for V5e support).\\n\",\n    \"# You must save `libtpu.so` in the '/lib' directory of the container image.\\n\",\n    \"RUN curl -L https://storage.googleapis.com/cloud-tpu-tpuvm-artifacts/libtpu/1.10.0/libtpu.so -o /lib/libtpu.so\\n\",\n    \"\\n\",\n    \"# Download and install tensorflow-datasets\\n\",\n    \"RUN pip3 install tensorflow-datasets\\n\",\n    \"\\n\",\n    \"# Copies the trainer code to the docker image.\\n\",\n    \"COPY train.py /root/train.py\\n\",\n    \"\\n\",\n    \"# Sets the default command to run train.py.\\n\",\n    \"CMD [\\\"python3\\\", \\\"train.py\\\"]\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cib87b1jsh4\",\n   \"metadata\": {},\n   \"source\": [\n    \"### Create the Training Script\\n\",\n    \"\\n\",\n    \"Write the contents of the training script to *train.py*.\\n\",\n    \"\\n\",\n    \"In summary, the training script does the following:\\n\",\n    \"\\n\",\n    \"- Gets the directory where to save the model artifacts from the environment variable `AIP_MODEL_DIR`. This variable is set by the training service.\\n\",\n    \"- Loads CIFAR10 dataset from TF Datasets (tfds).\\n\",\n    \"- Builds a model using TF.Keras model API.\\n\",\n    \"- Compiles the model.\\n\",\n    \"- Sets a training distribution strategy according to the argument `args.distribute`.\\n\",\n    \"- Trains the model with epochs and steps according to the arguments `args.epochs` and `args.steps`\\n\",\n    \"- Saves the trained model to the specified model directory.\\n\",\n    \"- Runs TPU specific tasks:\\n\",\n    \"    - Finds the TPU cluster, connects to the cluster, and sets the training strategy to TPUStrategy.\\n\",\n    \"    - Saves the trained TPU model to the local device so that the model can be saved to the location in `AIP_MODEL_DIR`.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"aoxpw5vdret\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"%%writefile tpu-container-artifacts/train.py\\n\",\n    \"# Single, Mirror and Multi-Machine Distributed Training for CIFAR-10\\n\",\n    \"\\n\",\n    \"import tensorflow_datasets as tfds\\n\",\n    \"import tensorflow as tf\\n\",\n    \"from tensorflow.python.client import device_lib\\n\",\n    \"import argparse\\n\",\n    \"import os\\n\",\n    \"import sys\\n\",\n    \"tfds.disable_progress_bar()\\n\",\n    \"\\n\",\n    \"parser = argparse.ArgumentParser()\\n\",\n    \"parser.add_argument('--lr', dest='lr',\\n\",\n    \"                    default=0.01, type=float,\\n\",\n    \"                    help='Learning rate.')\\n\",\n    \"parser.add_argument('--epochs', dest='epochs',\\n\",\n    \"                    default=10, type=int,\\n\",\n    \"                    help='Number of epochs.')\\n\",\n    \"parser.add_argument('--steps', dest='steps',\\n\",\n    \"                    default=200, type=int,\\n\",\n    \"                    help='Number of steps per epoch.')\\n\",\n    \"parser.add_argument('--distribute', dest='distribute', type=str, default='single',\\n\",\n    \"                    help='distributed training strategy')\\n\",\n    \"args = parser.parse_args()\\n\",\n    \"\\n\",\n    \"print('Python Version = {}'.format(sys.version))\\n\",\n    \"print('TensorFlow Version = {}'.format(tf.__version__))\\n\",\n    \"print('TF_CONFIG = {}'.format(os.environ.get('TF_CONFIG', 'Not found')))\\n\",\n    \"print('DEVICES', device_lib.list_local_devices())\\n\",\n    \"\\n\",\n    \"# Single Machine, single compute device\\n\",\n    \"if args.distribute == 'single':\\n\",\n    \"    if tf.test.is_gpu_available():\\n\",\n    \"        strategy = tf.distribute.OneDeviceStrategy(device=\\\"/gpu:0\\\")\\n\",\n    \"    else:\\n\",\n    \"        strategy = tf.distribute.OneDeviceStrategy(device=\\\"/cpu:0\\\")\\n\",\n    \"# Single Machine, multiple TPU devices\\n\",\n    \"elif args.distribute == 'tpu':\\n\",\n    \"    cluster_resolver = tf.distribute.cluster_resolver.TPUClusterResolver(tpu=\\\"local\\\")\\n\",\n    \"    tf.config.experimental_connect_to_cluster(cluster_resolver)\\n\",\n    \"    tf.tpu.experimental.initialize_tpu_system(cluster_resolver)\\n\",\n    \"    strategy = tf.distribute.TPUStrategy(cluster_resolver)\\n\",\n    \"    print(\\\"All devices: \\\", tf.config.list_logical_devices('TPU'))\\n\",\n    \"# Single Machine, multiple compute device\\n\",\n    \"elif args.distribute == 'mirror':\\n\",\n    \"    strategy = tf.distribute.MirroredStrategy()\\n\",\n    \"# Multiple Machine, multiple compute device\\n\",\n    \"elif args.distribute == 'multi':\\n\",\n    \"    strategy = tf.distribute.experimental.MultiWorkerMirroredStrategy()\\n\",\n    \"\\n\",\n    \"# Multi-worker configuration\\n\",\n    \"print('num_replicas_in_sync = {}'.format(strategy.num_replicas_in_sync))\\n\",\n    \"\\n\",\n    \"# Preparing dataset\\n\",\n    \"BUFFER_SIZE = 10000\\n\",\n    \"BATCH_SIZE = 64\\n\",\n    \"\\n\",\n    \"def make_datasets_unbatched():\\n\",\n    \"  # Scaling CIFAR10 data from (0, 255] to (0., 1.]\\n\",\n    \"  def scale(image, label):\\n\",\n    \"    image = tf.cast(image, tf.float32)\\n\",\n    \"    image /= 255.0\\n\",\n    \"    return image, label\\n\",\n    \"\\n\",\n    \"  datasets, info = tfds.load(name='cifar10',\\n\",\n    \"                            with_info=True,\\n\",\n    \"                            as_supervised=True)\\n\",\n    \"  return datasets['train'].map(scale).cache().shuffle(BUFFER_SIZE).repeat()\\n\",\n    \"\\n\",\n    \"\\n\",\n    \"# Build the Keras model\\n\",\n    \"def build_and_compile_cnn_model():\\n\",\n    \"  model = tf.keras.Sequential([\\n\",\n    \"      tf.keras.layers.Conv2D(32, 3, activation='relu', input_shape=(32, 32, 3)),\\n\",\n    \"      tf.keras.layers.MaxPooling2D(),\\n\",\n    \"      tf.keras.layers.Conv2D(32, 3, activation='relu'),\\n\",\n    \"      tf.keras.layers.MaxPooling2D(),\\n\",\n    \"      tf.keras.layers.Flatten(),\\n\",\n    \"      tf.keras.layers.Dense(10, activation='softmax')\\n\",\n    \"  ])\\n\",\n    \"  model.compile(\\n\",\n    \"      loss=tf.keras.losses.sparse_categorical_crossentropy,\\n\",\n    \"      optimizer=tf.keras.optimizers.SGD(learning_rate=args.lr),\\n\",\n    \"      metrics=['accuracy'])\\n\",\n    \"  return model\\n\",\n    \"\\n\",\n    \"# Train the model\\n\",\n    \"NUM_WORKERS = strategy.num_replicas_in_sync\\n\",\n    \"# Here the batch size scales up by number of workers since\\n\",\n    \"# `tf.data.Dataset.batch` expects the global batch size.\\n\",\n    \"GLOBAL_BATCH_SIZE = BATCH_SIZE * NUM_WORKERS\\n\",\n    \"MODEL_DIR = os.getenv(\\\"AIP_MODEL_DIR\\\")\\n\",\n    \"\\n\",\n    \"train_dataset = make_datasets_unbatched().batch(GLOBAL_BATCH_SIZE)\\n\",\n    \"\\n\",\n    \"with strategy.scope():\\n\",\n    \"  # Creation of dataset, and model building/compiling need to be within\\n\",\n    \"  # `strategy.scope()`.\\n\",\n    \"  model = build_and_compile_cnn_model()\\n\",\n    \"\\n\",\n    \"model.fit(x=train_dataset, epochs=args.epochs, steps_per_epoch=args.steps)\\n\",\n    \"if args.distribute==\\\"tpu\\\":\\n\",\n    \"    save_locally = tf.saved_model.SaveOptions(experimental_io_device='/job:localhost')\\n\",\n    \"    model.save(MODEL_DIR, options=save_locally)\\n\",\n    \"else:\\n\",\n    \"    model.save(MODEL_DIR)\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"99kqaux4qxe\",\n   \"metadata\": {},\n   \"source\": [\n    \"### Build the Training Container Image\\n\",\n    \"\\n\",\n    \"Build and push the training container image to Artifact Registry.\\n\",\n    \"\\n\",\n    \"1. Enable the Artifact Registry API.\\n\",\n    \"1. Create a private repository in Artifact Registry.\\n\",\n    \"1. Configure authentication to Artifact Registry.\\n\",\n    \"1. Submit the training container image using Cloud Build.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"8m6ol63f32b\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Set the project id\\n\",\n    \"! gcloud config set project {PROJECT_ID}\\n\",\n    \"# Enable Artifact Registry\\n\",\n    \"! gcloud services enable artifactregistry.googleapis.com\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"lidc3b0pic9\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Create the repository\\n\",\n    \"! gcloud artifacts repositories create $REPO_NAME --repository-format=docker \\\\\\n\",\n    \"    --location=$REGION --description=\\\"Vertex TPU training repository\\\" || true\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"z6dtean8ylh\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"! gcloud auth configure-docker $REGION-docker.pkg.dev --quiet\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"dq3qc17nhwm\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Set the training container image\\n\",\n    \"TRAIN_IMAGE = f\\\"{REGION}-docker.pkg.dev/{PROJECT_ID}/{REPO_NAME}/{TRAIN_IMAGE_ID}:{VERSION}\\\"\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"31sk7970z52\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Submit the build source\\n\",\n    \"! gcloud builds submit tpu-container-artifacts --region={REGION} --tag={TRAIN_IMAGE}\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"22p4xqzps9a\",\n   \"metadata\": {},\n   \"source\": [\n    \"## Custom Jobs\\n\",\n    \"\\n\",\n    \"Submit TPU training workloads using [Custom Jobs and Worker Pool Specs](https://cloud.google.com/vertex-ai/docs/training/create-custom-job).\\n\",\n    \"\\n\",\n    \"In this example, a CIFAR-10 classification model is trained using TPU accelerators.\\n\",\n    \"\\n\",\n    \"Learn more about [Training with TPU accelerators](https://cloud.google.com/vertex-ai/docs/training/training-with-tpu-vm).\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"tx24hspm0me\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Import libraries\\n\",\n    \"\\n\",\n    \"import os\\n\",\n    \"import kfp\\n\",\n    \"from kfp.registry import RegistryClient\\n\",\n    \"from kfp import compiler\\n\",\n    \"import kfp.components as comp\\n\",\n    \"from google.cloud import aiplatform\\n\",\n    \"from google.cloud.aiplatform import gapic\\n\",\n    \"from google_cloud_pipeline_components.v1.custom_job import CustomTrainingJobOp\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"q8kyz5d8xo\",\n   \"metadata\": {},\n   \"source\": [\n    \"### Set Hardware Accelerators and Training Parameters\\n\",\n    \"\\n\",\n    \"Set the TPU accelerator type and count for training. See the [locations where accelerators are available](https://cloud.google.com/vertex-ai/docs/general/locations#accelerators).\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"ebx73ytaiwm\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"[x for x in dir(gapic.AcceleratorType) if 'TPU' in x]\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"uuxkhqpofy\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"TRAIN_COMPUTE = \\\"ct5lp-hightpu-1t\\\"\\n\",\n    \"TPU_TOPOLOGY = \\\"1x1\\\"\\n\",\n    \"TRAIN_STRATEGY = \\\"single\\\"\\n\",\n    \"\\n\",\n    \"EPOCHS = 20\\n\",\n    \"STEPS = 10000\\n\",\n    \"\\n\",\n    \"TRAINER_ARGS = [\\n\",\n    \"  \\\"--epochs=\\\" + str(EPOCHS),\\n\",\n    \"  \\\"--steps=\\\" + str(STEPS),\\n\",\n    \"  \\\"--distribute=\\\" + TRAIN_STRATEGY,\\n\",\n    \"]\\n\",\n    \"\\n\",\n    \"print(\\\"Train machine type:\\\", TRAIN_COMPUTE)\\n\",\n    \"print(\\\"TPU Topology:\\\", TPU_TOPOLOGY)\\n\",\n    \"print(\\\"Trainer args:\\\", TRAINER_ARGS)\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"g3vv6dg56ug\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# WORKER_POOL_SPEC = [\\n\",\n    \"#     {\\n\",\n    \"#         \\\"replica_count\\\": 1,\\n\",\n    \"#         \\\"machine_spec\\\": {\\n\",\n    \"#             \\\"machine_type\\\": TRAIN_COMPUTE,\\n\",\n    \"#             \\\"tpu_topology\\\": TPU_TOPOLOGY,\\n\",\n    \"#         },\\n\",\n    \"#         \\\"container_spec\\\": {\\n\",\n    \"#             \\\"image_uri\\\": TRAIN_IMAGE,\\n\",\n    \"#             \\\"args\\\": TRAINER_ARGS,\\n\",\n    \"#             \\\"env\\\": [\\n\",\n    \"#                 {\\\"name\\\": \\\"AIP_MODEL_DIR\\\", \\\"value\\\": WORKING_DIR},\\n\",\n    \"#                 # Environment variables for 1x1 topology\\n\",\n    \"#                 {\\\"name\\\": \\\"TPU_CHIPS_PER_HOST_BOUNDS\\\", \\\"value\\\": \\\"1,1,1\\\"},\\n\",\n    \"#                 {\\\"name\\\": \\\"TPU_HOST_BOUNDS\\\", \\\"value\\\": \\\"1,1,1\\\"},\\n\",\n    \"#             ],\\n\",\n    \"#         },\\n\",\n    \"#     }\\n\",\n    \"# ]\\n\",\n    \"\\n\",\n    \"WORKER_POOL_SPEC = [\\n\",\n    \"  {\\n\",\n    \"    \\\"replica_count\\\": 1,\\n\",\n    \"    \\\"machine_spec\\\": {\\n\",\n    \"      \\\"machine_type\\\": TRAIN_COMPUTE,\\n\",\n    \"      \\\"tpu_topology\\\": TPU_TOPOLOGY,\\n\",\n    \"    },\\n\",\n    \"    \\\"container_spec\\\": {\\n\",\n    \"      \\\"image_uri\\\": TRAIN_IMAGE,\\n\",\n    \"      \\\"command\\\": [\\\"python3\\\", \\\"train.py\\\"],  # \u003c--- Add this line\\n\",\n    \"      \\\"args\\\": TRAINER_ARGS,\\n\",\n    \"      \\\"env\\\": [\\n\",\n    \"        {\\\"name\\\": \\\"AIP_MODEL_DIR\\\", \\\"value\\\": WORKING_DIR},\\n\",\n    \"        # Environment variables for 1x1 topology\\n\",\n    \"        {\\\"name\\\": \\\"TPU_CHIPS_PER_HOST_BOUNDS\\\", \\\"value\\\": \\\"1,1,1\\\"},\\n\",\n    \"        {\\\"name\\\": \\\"TPU_HOST_BOUNDS\\\", \\\"value\\\": \\\"1,1,1\\\"},\\n\",\n    \"      ],\\n\",\n    \"    },\\n\",\n    \"  }\\n\",\n    \"]\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"h98ln05iarv\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"aiplatform.init(project=PROJECT_ID, location=REGION, staging_bucket=PIPELINE_ROOT)\\n\",\n    \"\\n\",\n    \"custom_job = aiplatform.CustomJob(\\n\",\n    \"    display_name=\\\"gke-submitted-tpu-training-job\\\",\\n\",\n    \"    worker_pool_specs=WORKER_POOL_SPEC,\\n\",\n    \"    project=PROJECT_ID,\\n\",\n    \"    location=REGION,\\n\",\n    \"    staging_bucket=PIPELINE_ROOT,\\n\",\n    \")\\n\",\n    \"\\n\",\n    \"custom_job.run(sync=False, service_account=SERVICE_ACCOUNT)\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"0a9onefig1e\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"custom_job\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"p7yv6y9hlzl\",\n   \"metadata\": {},\n   \"source\": [\n    \"## Run Custom Job Component in a Kubeflow Pipeline\\n\",\n    \"\\n\",\n    \"Users have the option to incorporate the custom job into a Vertex Pipeline as part of a larger training and modeling work flow. Pipeline is stored and versioned in Artifact Registry.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"jmaa70mqyvs\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Create the KFP Artifact Registry repo\\n\",\n    \"! gcloud artifacts repositories create {PIPELINE_REPO} --repository-format=kfp \\\\\\n\",\n    \"    --location={REGION} --description=\\\"TPU training pipelines\\\" || true\\n\",\n    \"\\n\",\n    \"@kfp.dsl.pipeline(pipeline_root=PIPELINE_ROOT, name=PIPELINE_NAME)\\n\",\n    \"def pipeline():\\n\",\n    \"    tpu_job = CustomTrainingJobOp(\\n\",\n    \"        project=PROJECT_ID,\\n\",\n    \"        location=REGION,\\n\",\n    \"        display_name=\\\"tpu-training-workload\\\",\\n\",\n    \"        worker_pool_specs=WORKER_POOL_SPEC,\\n\",\n    \"        service_account=SERVICE_ACCOUNT,\\n\",\n    \"    ).set_display_name(\\\"tpu-training-workload\\\")\\n\",\n    \"\\n\",\n    \"\\n\",\n    \"# Compile Pipeline Job\\n\",\n    \"compiler.Compiler().compile(\\n\",\n    \"    pipeline_func=pipeline, package_path=os.path.join(\\\"/tmp\\\", \\\"tpu_training_pipeline.yaml\\\")\\n\",\n    \")\\n\",\n    \"\\n\",\n    \"# Upload Pipeline to Artifact Registry\\n\",\n    \"client = RegistryClient(\\n\",\n    \"    host=f\\\"https://{REGION}-kfp.pkg.dev/{PROJECT_ID}/{PIPELINE_REPO}\\\"\\n\",\n    \")\\n\",\n    \"templateName, versionName = client.upload_pipeline(\\n\",\n    \"    file_name=os.path.join(\\\"/tmp\\\", \\\"tpu_training_pipeline.yaml\\\"), tags=[\\\"v1\\\", VERSION]\\n\",\n    \")\\n\",\n    \"\\n\",\n    \"# Configure the pipeline\\n\",\n    \"job = aiplatform.PipelineJob(\\n\",\n    \"    display_name=\\\"tpu_training_pipeline\\\",\\n\",\n    \"    template_path=f\\\"https://{REGION}-kfp.pkg.dev/{PROJECT_ID}/{PIPELINE_REPO}/{PIPELINE_NAME}/{VERSION}\\\",\\n\",\n    \"    pipeline_root=PIPELINE_ROOT,\\n\",\n    \"    enable_caching=False,\\n\",\n    \")\\n\",\n    \"\\n\",\n    \"# Run the job\\n\",\n    \"job.run(sync=False)\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"7dgpb6t1k2r\",\n   \"metadata\": {},\n   \"source\": [\n    \"## Check Task Completion and Output\\n\",\n    \"\\n\",\n    \"Once the job and/or pipeline is complete, check to see the output of the TPU training job.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"besbk6wtf5c\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Check the status of the custom job\\n\",\n    \"custom_job.state\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"07i70doou1e\",\n   \"metadata\": {},\n   \"source\": [\n    \"## Cleanup\\n\",\n    \"\\n\",\n    \"To tear down all infrastructure (GKE cluster, IAM, JupyterHub), run `terraform destroy` from the `infra/` directory.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"zjslgruy9bo\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Delete the Artifact Registry repository\\n\",\n    \"! gcloud artifacts repositories delete $REPO_NAME --location=$REGION --quiet\\n\",\n    \"\\n\",\n    \"# Remove the training container artifacts\\n\",\n    \"! rm -rf tpu-container-artifacts\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"m0ih7uubbh8\",\n   \"metadata\": {},\n   \"source\": [\n    \"## Additional References\\n\",\n    \"\\n\",\n    \"* [Training with TPU accelerators](https://cloud.google.com/vertex-ai/docs/training/training-with-tpu-vm)\\n\",\n    \"* [Custom container training with TPU](https://cloud.google.com/vertex-ai/docs/training/training-with-tpu-vm#custom_container)\\n\",\n    \"* [TPU types](https://cloud.google.com/tpu/docs/system-architecture-tpu-vm)\\n\",\n    \"* [Prebuilt containers for training](https://cloud.google.com/vertex-ai/docs/training/pre-built-containers)\\n\",\n    \"* [Vertex AI Pipelines](https://cloud.google.com/vertex-ai/docs/pipelines)\\n\",\n    \"* [GKE Workload Identity](https://cloud.google.com/kubernetes-engine/docs/how-to/workload-identity)\"\n   ]\n  }\n ],\n \"metadata\": {\n  \"environment\": {\n   \"kernel\": \"python3\",\n   \"name\": \"workbench-notebooks.m117\",\n   \"type\": \"gcloud\",\n   \"uri\": \"us-docker.pkg.dev/deeplearning-platform-release/gcr.io/workbench-notebooks:m117\"\n  },\n  \"kernelspec\": {\n   \"display_name\": \"Python 3\",\n   \"language\": \"python\",\n   \"name\": \"python3\"\n  },\n  \"language_info\": {\n   \"name\": \"python\",\n   \"version\": \"3.10.0\"\n  }\n },\n \"nbformat\": 4,\n \"nbformat_minor\": 5\n}\n"
            },
