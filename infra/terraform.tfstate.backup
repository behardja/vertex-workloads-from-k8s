    {
      "mode": "managed",
      "type": "helm_release",
      "name": "jupyterhub",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 2,
          "attributes": {
            "atomic": false,
            "chart": "jupyterhub",
            "cleanup_on_fail": false,
            "create_namespace": false,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "jupyterhub",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": {
              "app_version": "5.4.3",
              "chart": "jupyterhub",
              "first_deployed": 1772783153,
              "last_deployed": 1772788274,
              "name": "jupyterhub",
              "namespace": "jupyterhub",
              "notes": "\n.      __                          __                  __  __          __\n      / / __  __  ____    __  __  / /_  ___    _____  / / / / __  __  / /_\n __  / / / / / / / __ \\  / / / / / __/ / _ \\  / ___/ / /_/ / / / / / / __ \\\n/ /_/ / / /_/ / / /_/ / / /_/ / / /_  /  __/ / /    / __  / / /_/ / / /_/ /\n\\____/  \\__,_/ / .___/  \\__, /  \\__/  \\___/ /_/    /_/ /_/  \\__,_/ /_.___/\n              /_/      /____/\n\n       You have successfully installed the official JupyterHub Helm chart!\n\n### Installation info\n\n  - Kubernetes namespace: jupyterhub\n  - Helm release name:    jupyterhub\n  - Helm chart version:   4.3.2\n  - JupyterHub version:   5.4.3\n  - Hub pod packages:     See https://github.com/jupyterhub/zero-to-jupyterhub-k8s/blob/4.3.2/images/hub/requirements.txt\n\n### Followup links\n\n  - Documentation:  https://z2jh.jupyter.org\n  - Help forum:     https://discourse.jupyter.org\n  - Social chat:    https://jupyter.zulipchat.com/#narrow/channel/469744-jupyterhub\n  - Issue tracking: https://github.com/jupyterhub/zero-to-jupyterhub-k8s/issues\n\n### Post-installation checklist\n\n  - Verify that created Pods enter a Running state:\n\n      kubectl --namespace=jupyterhub get pod\n\n    If a pod is stuck with a Pending or ContainerCreating status, diagnose with:\n\n      kubectl --namespace=jupyterhub describe pod \u003cname of pod\u003e\n\n    If a pod keeps restarting, diagnose with:\n\n      kubectl --namespace=jupyterhub logs --previous \u003cname of pod\u003e\n\n  - Verify an external IP is provided for the k8s Service proxy-public.\n\n      kubectl --namespace=jupyterhub get service proxy-public\n\n    If the external ip remains \u003cpending\u003e, diagnose with:\n\n      kubectl --namespace=jupyterhub describe service proxy-public\n\n  - Verify web based access:\n\n    You have not configured a k8s Ingress or Gateway resource so you need to access the k8s\n    Service proxy-public directly.\n\n    If your computer is outside the k8s cluster, you can port-forward traffic to\n    the k8s Service proxy-public with kubectl to access it from your\n    computer.\n\n      kubectl --namespace=jupyterhub port-forward service/proxy-public 8080:http\n\n    Try insecure HTTP access: http://localhost:8080\n\n",
              "revision": 7,
              "values": "{\"hub\":{\"config\":{\"Authenticator\":{\"admin_users\":[\"admin\"]},\"DummyAuthenticator\":{\"password\":\"vertex\"},\"JupyterHub\":{\"authenticator_class\":\"dummy\"}}},\"proxy\":{\"service\":{\"type\":\"LoadBalancer\"}},\"singleuser\":{\"cloudMetadata\":{\"blockWithIptables\":false},\"cpu\":{\"guarantee\":1,\"limit\":2},\"extraEnv\":{\"PATH\":\"/opt/google-cloud-sdk/bin:/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"},\"image\":{\"name\":\"quay.io/jupyterhub/singleuser\",\"tag\":\"4.1\"},\"initContainers\":[{\"command\":[\"cp\",\"-r\",\"/usr/lib/google-cloud-sdk/.\",\"/opt/gcloud/\"],\"image\":\"google/cloud-sdk:slim\",\"name\":\"install-gcloud\",\"volumeMounts\":[{\"mountPath\":\"/opt/gcloud\",\"name\":\"gcloud\"}]}],\"lifecycleHooks\":{\"postStart\":{\"exec\":{\"command\":[\"sh\",\"-c\",\"cp /tmp/notebook/submit_tpu_job.ipynb /home/jovyan/submit_tpu_job.ipynb 2\\u003e/dev/null\\necho 'export PATH=/opt/google-cloud-sdk/bin:$PATH' \\u003e\\u003e /home/jovyan/.bashrc 2\\u003e/dev/null\\ntrue\\n\"]}}},\"memory\":{\"guarantee\":\"2G\",\"limit\":\"4G\"},\"serviceAccountName\":\"jupyterhub-sa\",\"storage\":{\"capacity\":\"5Gi\",\"extraVolumeMounts\":[{\"mountPath\":\"/tmp/notebook\",\"name\":\"notebook\",\"readOnly\":true},{\"mountPath\":\"/opt/google-cloud-sdk\",\"name\":\"gcloud\"}],\"extraVolumes\":[{\"configMap\":{\"name\":\"submit-tpu-job-notebook\"},\"name\":\"notebook\"},{\"emptyDir\":{},\"name\":\"gcloud\"}]}}}",
              "version": "4.3.2"
            },
            "name": "jupyterhub",
            "namespace": "jupyterhub",
            "pass_credentials": false,
            "postrender": null,
            "recreate_pods": false,
            "render_subchart_notes": true,
